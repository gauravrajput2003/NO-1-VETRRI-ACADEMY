{
  "expo": {
    "name": "No.1 Vettri Academy",
    "slug": "no-1-vettri-academy",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo_playstore.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A1628"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.vettriacademy.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo_playstore.png",
        "backgroundColor": "#0A1628"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.vettriacademy.app",
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      "@react-native-community/datetimepicker",
      "expo-audio",
      "expo-asset",
      [
        "expo-notifications",
        {
          "color": "#0A1628",
          "defaultChannel": "vettri-default"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "546a14a2-77ac-4b76-8596-097f8e81d7d8"
      }
    },
    "owner": "vettriinstitutes-organization"
  }
}
